# --- Telegram App Credentials (MTProto) ---
# Create these at https://my.telegram.org/
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

# --- Telegram Channel ID (where files are stored) ---
TELEGRAM_CHANNEL_ID=your_telegram_channel_id

# --- Access Control & Security ---
# Comma-separated list of Telegram user IDs allowed to access the drive
ALLOWED_USER_IDS=your_allowed_user_id

# --- Web JWT Secret & Session Encryption ---
JWT_SECRET=your_jwt_secret_for_sessions
# Key used to encrypt file buffers and the MTProto string session (32-byte hex string)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# --- Web URL ---
WEB_URL=http://localhost:5000

# --- Telegram User Session (MTProto) ---
# Generate this string by running: node backend/gen_session.js
TELEGRAM_STRING_SESSION=your_telegram_string_session

# --- Supabase Database Configuration (For Vercel Serverless) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
