{
  "name": "telegram-drive-project",
  "version": "1.0.0",
  "description": "Integrated Telegram Cloud Drive Web & Bot Project",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend && node build.js",
    "start": "npm start --prefix backend",
    "dev": "npm run build && npm start --prefix backend"
  },
  "dependencies": {
    "@cryptography/aes": "^0.1.1",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.6.8",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "telegram": "^2.26.22"
  }
}
